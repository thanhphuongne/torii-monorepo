# ========================================
# Docker Compose Configuration
# ========================================
# Used for variable substitution in docker-compose.yml
# ========================================

# Your Docker Hub username for pulling backend images
DOCKER_USERNAME=yourusername

# ========================================
# Application Configuration
# ========================================
# All application-level settings (JWT, API keys, etc.) are 
# handled via apps/server/config/config.yaml.
#
# ACTION REQUIRED:
# Copy apps/server/config/config.sample.yaml to apps/server/config/config.yaml
# and fill in your specific credentials.
# ========================================

DOCKER_USERNAME=lain4504
NODE_ENV=development

# ========================================
# LiveKit Configuration
# ========================================
# ACTION REQUIRED: Set this to your VPS public IP.
# Run: curl ifconfig.me
VPS_PUBLIC_IP=

# Infrastructure Settings (must be updated in config.yaml)
# DATABASE_URL, NATS_URL, REDIS_HOST, etc. should be configured 
# directly in apps/server/config/config.yaml to match the 
# services defined in docker-compose.yml.