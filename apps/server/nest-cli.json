{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/gateway/src",
  "monorepo": true,
  "root": ".",
  "compilerOptions": {
    "deleteOutDir": false,
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json",
    "plugins": [],
    "assets": []
  },
  "projects": {
    "gateway": {
      "type": "application",
      "root": "services/gateway",
      "entryFile": "main",
      "sourceRoot": "services/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "services/gateway/tsconfig.app.json",
        "webpack": false
      }
    },
    "identity": {
      "type": "application",
      "root": "services/identity",
      "entryFile": "main",
      "sourceRoot": "services/identity/src",
      "compilerOptions": {
        "tsConfigPath": "services/identity/tsconfig.app.json",
        "webpack": false,
        "assets": [
          {
            "include": "**/*.pug",
            "outDir": "dist/services/identity/src",
            "watchAssets": true
          }
        ]
      }
    },
    "meet": {
      "type": "application",
      "root": "services/meet",
      "entryFile": "main",
      "sourceRoot": "services/meet/src",
      "compilerOptions": {
        "tsConfigPath": "services/meet/tsconfig.app.json",
        "webpack": false
      }
    },
    "academy": {
      "type": "application",
      "root": "services/academy",
      "entryFile": "main",
      "sourceRoot": "services/academy/src",
      "compilerOptions": {
        "tsConfigPath": "services/academy/tsconfig.app.json",
        "webpack": false
      }
    },
    "agents": {
      "type": "application",
      "root": "services/agents",
      "entryFile": "main",
      "sourceRoot": "services/agents/src",
      "compilerOptions": {
        "tsConfigPath": "services/agents/tsconfig.app.json",
        "webpack": false,
        "assets": [
          {
            "include": "assets/**/*",
            "outDir": "dist/services/agents/src",
            "watchAssets": true
          }
        ]
      }
    }
  }
}