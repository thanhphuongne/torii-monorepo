{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/meet/src",
  "monorepo": true,
  "root": ".",
  "compilerOptions": {
    "deleteOutDir": false,
    "webpack": true,
    "tsConfigPath": "tsconfig.build.json",
    "plugins": [],
    "assets": []
  },
  "projects": {
    "meet": {
      "type": "application",
      "root": "services/meet",
      "entryFile": "main",
      "sourceRoot": "services/meet/src",
      "compilerOptions": {
        "tsConfigPath": "services/meet/tsconfig.app.json",
        "webpack": false
      }
    }
  }
}