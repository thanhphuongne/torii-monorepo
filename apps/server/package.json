{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "cd ../../packages/protocol && npm run build && cd ../../packages/schemas && pnpm run build && cd ../../apps/server && rimraf dist && npx prisma generate && nest build meet",
    "format": "prettier --write \"{modules,services,libs}/**/*.ts\"",
    "start": "nest start meet",
    "start:dev": "nest start meet --watch",
    "start:debug": "nest start meet --debug --watch",
    "dev": "nest start meet --watch",
    "dev:meet": "nest start meet --watch",
    "prod:meet": "node dist/services/meet/src/main",
    "lint": "eslint \"{modules,services,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.956.0",
    "@aws-sdk/s3-request-presigner": "^3.956.0",
    "@bufbuild/protobuf": "^2.10.2",
    "@google/generative-ai": "^0.24.1",
    "@keyv/redis": "^5.1.5",
    "@livekit/protocol": "^1.43.4",
    "@nats-io/jwt": "0.0.10-5",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@workspace/protocol": "workspace:*",
    "@workspace/schemas": "workspace:*",
    "axios": "^1.13.2",
    "axios-retry": "^4.5.0",
    "body-parser": "^2.2.1",
    "cache-manager": "^7.2.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "long": "^5.3.2",
    "nats": "^2.29.3",
    "nkeys.js": "^1.1.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.12",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.2",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "9.0.8",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.4.2",
    "prisma": "^7.1.0",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/services/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@server/shared(|/.*)$": "<rootDir>/libs/shared/src/$1",
      "^@server/meet(|/.*)$": "<rootDir>/services/meet/src/$1",
      "^@prisma/generated$": "<rootDir>/generated/prisma/client",
      "^@prisma/generated/(.*)$": "<rootDir>/generated/prisma/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}