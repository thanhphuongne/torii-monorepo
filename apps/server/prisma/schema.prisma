// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ==================================================
// ENUMS
// ==================================================

// --- Academy Quiz/Exam (NEW) ---

enum AcademyExamType {
  QUIZ
  MODULE_TEST
  FINAL_EXAM
}

enum AcademyExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AcademyQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
  SHORT_ANSWER
  GROUP_PARENT
}

enum AcademyQuestionCategoryType {
  VOCABULARY
  GRAMMAR
  KANJI
  READING
  LISTENING
}

enum AcademyQuestionReviewStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum AcademyAssessmentKind {
  LESSON_CHECKPOINT
  MODULE_CHECKPOINT
  FINAL_EXAM
}

enum AcademyAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  CANCELLED
}

// --- Assessment ---

enum AssignmentType {
  TEXT // Text answer only
  FILE // File upload only
  BOTH // Text + File
}

enum SubmissionStatus {
  DRAFT // Đang soạn (chưa nộp)
  SUBMITTED // Đã nộp
  GRADED // Đã chấm
  RETURNED // Trả lại để sửa
}

// --- Flashcard / SRS ---

enum SrsState {
  LEARNING
  MASTERED
}

enum StudySetSourceType {
  USER
  SYSTEM
}

// --- Commerce ---

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
  REFUNDED
  FAILED
}

enum OrderType {
  COURSE
  BUNDLE
  SUBSCRIPTION
}

enum PaymentMethod {
  PAYOS
  BANK_TRANSFER
  MANUAL
  COIN
}

enum PaymentGateway {
  PAYOS
  MOMO
  STRIPE
  INTERNAL
}

enum CouponStatus {
  ACTIVE
  INACTIVE
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

/// Chỉ còn GLOBAL — không còn giới hạn theo từng sản phẩm (liveClass/vod) qua metadata.
enum CouponScope {
  GLOBAL
}

enum VodStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ARCHIVED
}

enum CohortStatus {
  DRAFT
  PENDING_APPROVAL
  OPENING
  COMPLETED
  ARCHIVED
}

enum LiveClassStatus {
  DRAFT
  OPENING      // Đang tuyển sinh
  IN_PROGRESS  // Đang diễn ra (đóng đăng ký, đang học)
  COMPLETED
  ARCHIVED
}

enum MinStudentsEnforcement {
  STRICT
  NOTIFY
  DISABLED
}

enum LiveScheduleRequestType {
  RESCHEDULE
}

enum LiveScheduleRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// --- Support ---

enum TicketType {
  REFUND
  SUPPORT
  ERROR_REPORT
}

enum TicketStatus {
  PENDING
  PROCESSING
  RESOLVED
  CANCELLED
}

// --- Gamification ---

enum ActivityType {
  LESSON_COMPLETE
  QUIZ_ANSWER
  VIDEO_WATCH
  REVIEW
  PRACTICE
  FLASHCARD_REVIEW
  EXAM_COMPLETE
  BLOG_CREATE
  COMMENT_CREATE
  LOGIN
}

enum GamificationTransactionType {
  EARN // Nhận điểm từ hoạt động học tập
  REDEEM // Đổi điểm lấy coupon/quà
  BONUS // Điểm thưởng bonus
  EXPIRATION // Điểm hết hạn
  OTHER // Khác
}

enum GamificationCurrency {
  POINT
  XP
}

enum AcademyFolderType {
  LIVE_CLASS_SHARED
  GENERAL
  SHARED
  PRIVATE
}

enum AcademyFolderOwnerType {
  SYSTEM
  LECTURER
  LIVE_CLASS
  COURSE_VOD
  USER
}

enum AcademyResourceType {
  FILE
  LINK
}

enum AcademyResourceVisibility {
  ENROLLED_ONLY
  PUBLIC
  PRIVATE
}

// ==================================================
// 1. LIVE SESSIONS & SCHEDULING (Meet / phòng học)
// ==================================================

// --- Room Artifacts ---

model RoomInfo {
  id                 Int    @id @default(autoincrement())
  roomTitle          String @default("") @map("room_title") @db.VarChar(255)
  roomId             String @map("room_id") @db.VarChar(64)
  sid                String @unique @map("sid") @db.VarChar(64)
  joinedParticipants Int    @default(0) @map("joined_participants")

  liveClassId String? @map("live_class_id") @db.Uuid
  weekday     Int?
  startTime   String? @map("start_time") @db.VarChar(20)

  // Int, 1 for true 2 for false
  isRunning    Int    @default(0) @map("is_running")
  isRecording  Int    @default(0) @map("is_recording")
  recorderId   String @default("") @map("recorder_id") @db.VarChar(36)
  isActiveRtmp Int    @default(0) @map("is_active_rtmp")
  rtmpNodeId   String @default("") @map("rtmp_node_id") @db.VarChar(36)
  webhookUrl   String @default("") @map("webhook_url") @db.VarChar(255)

  isBreakoutRoom Int       @default(0) @map("is_breakout_room")
  parentRoomId   String    @default("") @map("parent_room_id") @db.VarChar(64)
  creationTime   Int       @default(0) @map("creation_time")
  created        DateTime  @default(now()) @map("created")
  ended          DateTime? @map("ended") // Nullable - null means not ended yet (PostgreSQL compatible)
  modified       DateTime  @default(now()) @updatedAt @map("modified")

  // Relations
  artifacts RoomArtifact[]

  @@index([roomId, isRunning], map: "idx_room_id")
  @@index([liveClassId])
  @@map("room_info")
}

model RoomFile {
  id        Int      @id @default(autoincrement())
  fileId    String   @unique @map("file_id")
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  filePath  String   @map("file_path")
  fileType  String   @map("file_type")
  mimeType  String   @map("mime_type")
  fileSize  Float    @default(0) @map("file_size")
  createdAt DateTime @default(now()) @map("created")

  @@index([roomId])
  @@map("room_files")
}

model RoomArtifact {
  id          BigInt   @id @default(autoincrement())
  artifactId  String   @unique @map("artifact_id") @db.VarChar(64)
  roomTableId Int      @map("room_table_id")
  roomId      String   @map("room_id") @db.VarChar(255)
  type        String   @db.VarChar(100)
  metadata    Json?
  created     DateTime @default(now())

  // Relation to RoomInfo
  roomInfo RoomInfo @relation(fields: [roomTableId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@index([artifactId], map: "idx_artifact_artifact_id")
  @@index([roomId], map: "idx_artifact_room_id")
  @@index([type], map: "idx_artifact_type")
  @@map("room_artifacts")
}

// ==================================================
// 2. FLASHCARD / SRS
// ==================================================

// --- Flashcards & Notes ---

model StudySet {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  title       String  @db.VarChar(255)
  description String? @db.Text
  isPublic    Boolean @default(false) @map("is_public")
  sourceType  StudySetSourceType @default(USER) @map("source_type")
  shareToken  String? @unique @map("share_token") @db.VarChar(64)
  settings    Json?   @default("{}") @map("settings") @db.JsonB
  stats       Json?   @default("{\"cardCount\": 0, \"masteredCount\": 0}") @map("stats") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  setCards SetCard[]

  @@index([userId])
  @@index([sourceType, isPublic])
  @@map("academy_study_sets")
}

model SetCard {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studySetId      String   @map("study_set_id") @db.Uuid
  term            String   @map("term") @db.Text
  definition      String   @map("definition") @db.Text
  hint            String?  @map("hint") @db.Text
  mediaUrl        String?  @map("media_url") @db.Text
  languageDetails Json?    @map("language_details") @db.JsonB
  tags            String[] @default([]) @db.VarChar(50)

  sourceDocumentId String? @map("source_document_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  studySet       StudySet   @relation(fields: [studySetId], references: [id], onDelete: Cascade)
  sourceDocument FileAsset? @relation("SetCardSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  srsProgresses  SetCardSrsProgress[]

  @@index([studySetId])
  @@index([sourceDocumentId])
  @@map("academy_set_cards")
}

model SetCardSrsProgress {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  setCardId    String   @map("set_card_id") @db.Uuid
  srsState     SrsState @default(LEARNING) @map("srs_state")
  nextReviewAt DateTime @default(now()) @map("next_review_at")
  interval     Int      @default(0) @map("interval")
  easeFactor   Decimal  @default(2.5) @map("ease_factor") @db.Decimal(4, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  setCard SetCard @relation(fields: [setCardId], references: [id], onDelete: Cascade)

  @@unique([userId, setCardId])
  @@index([userId, nextReviewAt])
  @@index([setCardId])
  @@map("academy_set_card_srs_progress")
}

// ==================================================
// 7. USER & AUTH
// ==================================================

// --- Identity ---

model User {
  id          String @id @default(uuid()) @db.Uuid
  email       String @unique @db.VarChar(255)
  displayName String @map("display_name") @db.VarChar(100)

  // Auth fields
  password String? @db.VarChar(255) // Nullable for OAuth-only users

  // Profile fields
  avatarUrl String? @map("avatar_url") @db.Text

  // Metadata (JSON for flexibility)
  appMetadata  Json? @default("{}") @map("app_metadata") // App-specific data (providers, etc.)
  userMetadata Json? @default("{}") @map("user_metadata") // User profile data from OAuth

  // Role
  role String @default("learner") @db.VarChar(50)

  // Timestamps (replace status field - Supabase pattern)
  verifiedAt   DateTime? @map("verified_at") @db.Timestamp() // null = not verified (pending)
  bannedUntil  DateTime? @map("banned_until") @db.Timestamp() // null = not banned, value = banned until this time
  lastSignInAt DateTime? @map("last_sign_in_at") @db.Timestamp()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp() // null = not deleted, value = soft deleted

  // Relations
  identities     UserIdentity[] // OAuth providers (email, google, etc.)
  sessions       Session[]
  twoFactorAuth  TwoFactorAuth?
  studySets      StudySet[]
  comments       Comment[]
  auditLogs      AuditLog[]     @relation("UserAuditLogs")
  orders         Order[]
  tickets        Ticket[]       @relation("UserTickets")
  handledTickets Ticket[]       @relation("HandlerTickets")
  certificates   Certificate[]

  // Gamification Relations
  gamification UserGamification?
  streak       Streak?
  streakLogs   StreakLog[]

  // Commerce (New)
  couponUsages CouponUsage[]

  commentLikes CommentLike[]

  // History Relations
  gamificationHistories           GamificationHistory[]
  setCardSrsProgresses            SetCardSrsProgress[]
  blogs                           Blog[]
  // Academy V2 relations
  academyEnrollments              Enrollment[]
  academyAssignmentSubmissions    AssignmentSubmission[]
  academyUserLessonProgress       UserLessonProgress[]   @relation("AcademyUserLessonProgress")
  academyClassesTaught            LiveClass[]            @relation("AcademyClassTeacher")
  academyVodPackagesTaught        VodPackage[]           @relation("AcademyVodTeacher")
  academyClassReviews             CourseReview[]
  userAchievements                UserAchievement[]
  academyClassAttendances         ClassAttendance[]
  liveScheduleRequests            LiveScheduleRequest[]  @relation("LiveScheduleRequestRequester")
  reviewedLiveScheduleRequests    LiveScheduleRequest[]  @relation("LiveScheduleRequestReviewer")
  proposedTeacherScheduleRequests LiveScheduleRequest[]  @relation("LiveScheduleRequestProposedTeacher")
  aiUserSubscriptions             AiUserSubscription[]
  walletBalance                   Decimal                @default(0) @map("wallet_balance") @db.Decimal(12, 2)
  walletTransactions              WalletTransaction[]
  deviceTokens                    UserDeviceToken[]
  academyResourcesCreated         AcademyResource[]      @relation("AcademyResourceCreator")
  academyExamAttempts             AcademyExamAttempt[]

  // JLPT Mock (isolated)
  jlptMockAttempts JlptMockAttempt[] @relation("JlptMockAttemptUser")

  // Onboarding
  isOnboarded      Boolean           @default(false) @map("is_onboarded")
  /// Mục tiêu JLPT để gợi ý khoá học (N1..N5)
  jlptTarget   String? @map("jlpt_target") @db.VarChar(4)
  /// Trình độ hiện tại (tuỳ chọn)
  currentLevel String? @map("current_level") @db.VarChar(20)

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserIdentity {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Provider info
  provider   String @db.VarChar(50) // 'email', 'google', etc.
  providerId String @map("provider_id") @db.VarChar(255) // Provider's user ID

  // Provider metadata
  providerData Json? @map("provider_data") // Raw data from provider

  // Timestamps
  lastSignInAt DateTime? @map("last_sign_in_at") @db.Timestamp()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId]) // Prevent duplicate provider accounts
  @@index([userId])
  @@index([provider])
  @@map("user_identities")
}

model Session {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  tokenHash String @unique @map("token_hash") @db.VarChar(64) // SHA-256 hash

  // Device & Metadata
  deviceInfo String? @map("device_info") @db.VarChar(100) // e.g., "iPhone 13, iOS 15" or "Chrome on Windows"
  userAgent  String? @map("user_agent")  @db.Text
  ipAddress  String? @map("ip_address") @db.VarChar(45)  // Support IPv6

  expiresAt DateTime  @map("expires_at") @db.Timestamp()
  revokedAt DateTime? @map("revoked_at") @db.Timestamp()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model TwoFactorAuth {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // 2FA Status
  isEnabled Boolean @default(false) @map("is_enabled")
  method    String? @db.VarChar(20) // Currently only 'totp' supported (Google Authenticator)

  // TOTP Configuration (for Google Authenticator)
  totpSecret      String?  @map("totp_secret") @db.VarChar(255) // Encrypted with AES-256-GCM
  totpBackupCodes String[] @default([]) @map("totp_backup_codes") @db.VarChar(100) // Hashed with Argon2

  // Security & Metadata
  enabledAt      DateTime? @map("enabled_at") @db.Timestamp()
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamp()
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamp()

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor_auth")
}

// --- Permissions & Audit ---

model Role {
  code        String   @id @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  @@map("roles")
}

model RolePermission {
  roleCode       String   @map("role_code") @db.VarChar(50)
  permissionCode String   @map("permission_code") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp()

  @@id([roleCode, permissionCode])
  @@index([roleCode])
  @@map("role_permissions")
}

model AuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Who performed the action
  userId String @map("user_id") @db.Uuid

  // What action was performed
  action   String  @db.VarChar(100) // e.g., "permission.grant", "user.create", "course.delete"
  entity   String  @db.VarChar(100) // e.g., "role_permission", "user", "course"
  entityId String? @map("entity_id") @db.VarChar(255) // ID of affected entity

  // Action details
  description String @db.Text // Human-readable description
  metadata    Json? // Flexible JSON for action-specific data

  // State changes (for updates)
  oldValues Json? @map("old_values") // Previous state
  newValues Json? @map("new_values") // New state

  // Timestamp
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user User @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// --- Orders & Payments ---

model Order {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String        @unique @db.VarChar(50) // ORD-20260306-XXXX
  userId        String        @map("user_id") @db.Uuid
  status        OrderStatus   @default(PENDING)
  subTotal      Decimal       @map("sub_total") @db.Decimal(12, 2)
  discountTotal Decimal       @map("discount_total") @db.Decimal(12, 2)
  grandTotal    Decimal       @map("grand_total") @db.Decimal(12, 2)
  currency      String        @default("VND") @db.VarChar(10)
  couponCode    String?       @map("coupon_code") @db.VarChar(50)
  couponId      String?       @map("coupon_id") @db.Uuid
  note          String?       @db.Text
  paymentMethod PaymentMethod @map("payment_method")
  metadata      Json?         @default("{}") @db.JsonB
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon       Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  transactions Transaction[]
  usages       CouponUsage[]
  enrollments  Enrollment[]
  tickets      Ticket[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("academy_orders")
}

model OrderItem {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId            String  @map("order_id") @db.Uuid
  vodPackageId       String? @map("vod_package_id") @db.Uuid
  cohortId           String? @map("cohort_id") @db.Uuid
  liveClassId        String? @map("live_class_id") @db.Uuid
  subscriptionPlanId String? @map("subscription_plan_id") @db.Uuid
  price              Decimal @db.Decimal(12, 2)
  /// Ảnh chụp giá/tên/mô tả dòng hàng lúc thanh toán.
  deliverySnapshot   Json    @map("delivery_snapshot") @db.JsonB

  // Relations
  order            Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vodPackage       VodPackage?         @relation(fields: [vodPackageId], references: [id], onDelete: Cascade)
  cohort           Cohort?             @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  liveClass        LiveClass?          @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  subscriptionPlan AiSubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([vodPackageId])
  @@index([cohortId])
  @@index([liveClassId])
  @@index([subscriptionPlanId])
  @@map("academy_order_items")
}

model Transaction {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String         @map("order_id") @db.Uuid
  gateway         PaymentGateway
  transactionCode String?        @map("transaction_code") @db.VarChar(100)
  amount          Decimal        @db.Decimal(12, 2)
  status          String         @db.VarChar(20) // PENDING, SUCCESS, FAILED
  responsePayload Json?          @map("response_payload") @db.JsonB
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([transactionCode])
  @@map("academy_transactions")
}

// --- Coupons & Wishlist ---

model Coupon {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String             @unique @db.VarChar(50)
  name              String?            @db.VarChar(200)
  description       String?            @db.Text
  discountType      CouponDiscountType @map("discount_type")
  discountValue     Decimal            @map("discount_value") @db.Decimal(12, 2)
  maxDiscountAmount Decimal?           @map("max_discount_amount") @db.Decimal(12, 2)
  minOrderValue     Decimal?           @map("min_order_value") @db.Decimal(12, 2)
  usageLimit        Int?               @map("usage_limit")
  usageCount        Int                @default(0) @map("usage_count")
  perUserLimit      Int                @default(1) @map("per_user_limit")
  /// Phạm vi: hiện chỉ GLOBAL. Coupon cá nhân phân biệt bằng `ownerId`, không bằng scope.
  startDate         DateTime?          @map("start_date")
  endDate           DateTime?          @map("end_date")
  status            CouponStatus       @default(ACTIVE)
  scope             CouponScope        @default(GLOBAL)
  /// Ví dụ coupon đổi điểm gamification — gắn một user
  ownerId           String?            @map("owner_id") @db.Uuid
  /// Logical source for audit/analytics: MANUAL, CAMPAIGN, GAMIFICATION_REWARD, etc.
  source            String?            @db.VarChar(50)
  metadata          Json?              @default("{}") @db.JsonB
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")

  // Relations
  orders Order[]
  usages CouponUsage[]

  @@map("academy_coupons")
}

model CouponUsage {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId String   @map("coupon_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  orderId  String   @map("order_id") @db.Uuid
  usedAt   DateTime @default(now()) @map("used_at")

  // Relations
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade) // Added implicitly if needed

  @@index([couponId])
  @@index([userId])
  @@map("academy_coupon_usages")
}

