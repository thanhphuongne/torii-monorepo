// ==================================================
// LIVE CLASS SCHEDULE LAYER (Giữ nguyên)
// ==================================================

model LiveSchedule {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  liveClassId   String  @map("live_class_id") @db.Uuid
  weekday       Int // 0-6
  startTime     String  @map("start_time") @db.VarChar(20)
  endTime       String  @map("end_time") @db.VarChar(20)
  location      String? @db.VarChar(255)
  excludedDates Json?   @map("excluded_dates") @db.JsonB
  note          String? @db.Text
  roomId        String? @map("room_id") @db.VarChar(64)

  liveClass LiveClass             @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  sessions  LiveScheduleSession[]

  @@index([liveClassId])
  @@map("academy_live_schedules")
}

/// Live session instance theo ngày cho từng buổi học cụ thể
model LiveScheduleSession {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  liveClassId String  @map("live_class_id") @db.Uuid
  scheduleId  String? @map("schedule_id") @db.Uuid

  /// Ngày diễn ra buổi học (theo timezone vận hành, lưu ở UTC)
  sessionDate DateTime @map("session_date")

  /// Giờ bắt đầu/kết thúc (HH:mm, text)
  startTime String @map("start_time") @db.VarChar(20)
  endTime   String @map("end_time") @db.VarChar(20)

  status String @default("SCHEDULED") @db.VarChar(20) // SCHEDULED, CANCELLED, RESCHEDULED, COMPLETED

  cancellationReason String? @map("cancellation_reason") @db.Text

  roomId       String? @map("room_id") @db.VarChar(64)
  location     String? @db.VarChar(255)
  note         String? @db.Text
  instructorId String? @map("instructor_id") @db.Uuid

  supersededBySessionId String? @map("superseded_by_session_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid

  // Relations
  liveClass LiveClass     @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  schedule  LiveSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  supersededBySession LiveScheduleSession?  @relation("LiveScheduleSessionSupersede", fields: [supersededBySessionId], references: [id])
  supersededSessions  LiveScheduleSession[] @relation("LiveScheduleSessionSupersede")
  requests            LiveScheduleRequest[]
  attendances         ClassAttendance[]

  @@unique([liveClassId, sessionDate, startTime, endTime])
  @@index([liveClassId, sessionDate])
  @@index([scheduleId])
  @@index([status])
  @@map("academy_live_schedule_sessions")
}

model LiveScheduleRequest {
  id                String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String                    @map("session_id") @db.Uuid
  liveClassId       String?                   @map("live_class_id") @db.Uuid
  requestedBy       String                    @map("requested_by") @db.Uuid
  type              LiveScheduleRequestType
  status            LiveScheduleRequestStatus @default(PENDING)
  reason            String?                   @db.Text
  requestedDate     DateTime?                 @map("requested_date")
  originalWeekday   Int                       @map("original_weekday")
  originalStartTime String                    @map("original_start_time") @db.VarChar(20)
  originalEndTime   String                    @map("original_end_time") @db.VarChar(20)
  proposedDate      DateTime?                 @map("proposed_date")
  proposedStartTime String?                   @map("proposed_start_time") @db.VarChar(20)
  proposedEndTime   String?                   @map("proposed_end_time") @db.VarChar(20)
  proposedTeacherId String?                   @map("proposed_teacher_id") @db.Uuid
  reviewNote        String?                   @map("review_note") @db.Text
  reviewedBy        String?                   @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime?                 @map("reviewed_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @default(now()) @updatedAt @map("updated_at")

  session         LiveScheduleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  requester       User                @relation("LiveScheduleRequestRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewer        User?               @relation("LiveScheduleRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  proposedTeacher User?               @relation("LiveScheduleRequestProposedTeacher", fields: [proposedTeacherId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([requestedBy])
  @@index([status])
  @@index([requestedDate])
  @@map("academy_live_schedule_requests")
}

// ==================================================
// COMMERCE & ENROLLMENT LAYER
// ==================================================

/// Ghi danh: một VodPackage (VOD) hoặc một LiveClass (LIVE). Cohort không có cột ở đây — truy qua LiveClass.cohortId.
model Enrollment {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid

  vodPackageId String? @map("vod_package_id") @db.Uuid
  liveClassId  String? @map("live_class_id") @db.Uuid

  enrolledAt    DateTime  @default(now()) @map("enrolled_at")
  expiresAt     DateTime? @map("expires_at")
  status        String    @default("ACTIVE") @db.VarChar(20) // ACTIVE, EXPIRED, CANCELLED
  sourceOrderId String?   @map("source_order_id") @db.Uuid

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vodPackage VodPackage? @relation(fields: [vodPackageId], references: [id], onDelete: Cascade)
  liveClass  LiveClass?  @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  order          Order?               @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
  certificate    Certificate?
  review         CourseReview?
  lessonProgress UserLessonProgress[]
  academyExamAttempts AcademyExamAttempt[]

  @@unique([userId, vodPackageId])
  @@unique([userId, liveClassId])
  @@index([userId])
  @@index([vodPackageId])
  @@index([liveClassId])
  @@map("academy_enrollments")
}

