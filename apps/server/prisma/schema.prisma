model Certificate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  liveClassId     String?  @map("live_class_id") @db.Uuid
  vodPackageId    String?  @map("vod_package_id") @db.Uuid
  enrollmentId    String   @unique @map("enrollment_id") @db.Uuid
  certificateCode String   @unique @map("certificate_code") @db.VarChar(50)
  issueDate       DateTime @default(now()) @map("issue_date")
  fileUrl         String   @map("file_url") @db.Text
  score           Decimal? @db.Decimal(5, 2)
  metadata        Json?    @default("{}")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClass  LiveClass?  @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  vodPackage VodPackage? @relation(fields: [vodPackageId], references: [id], onDelete: Cascade)
  enrollment Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([liveClassId])
  @@index([vodPackageId])
  @@map("certificates")
}

// --- Notes ---

// ==================================================
// 12. ACADEMY CORE LMS V2 (Strictly Typed — No JSON Metadata)
// ==================================================

// Syllabus status

// Course Profile status
enum CourseProfileStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ARCHIVED
}

// Lesson content type
enum LessonType {
  VIDEO
  READING
}

model CourseProfile {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String              @unique @db.VarChar(100)
  title        String              @db.VarChar(255)
  description  String?             @db.Text
  level        String?             @db.VarChar(50) // N5, N4, N3, N2, N1
  thumbnailUrl String?             @map("thumbnail_url") @db.Text
  status       CourseProfileStatus @default(DRAFT)

  // Approval workflow
  submittedForApprovalAt DateTime? @map("submitted_for_approval_at")
  submittedBy            String?   @map("submitted_by") @db.Uuid
  approvedAt             DateTime? @map("approved_at")
  approvedBy             String?   @map("approved_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  modules                  Module[]
  vodPackages              VodPackage[]
  cohorts                  Cohort[]
  academyExams             AcademyExam[]
  academyAssessmentPlans   AcademyCourseProfileAssessment[]

  @@index([level])
  @@map("academy_course_profiles")
}

// LiveTerm model has been removed to simplify the hierarchy. 

// Syllabus has been removed to simplify the hierarchy as per Product-Centric refactor.
// Modules now link directly to CourseProfile.
/// Module (chương/bài) là folder chứa các bài học thực tế
model Module {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseProfileId String   @map("course_profile_id") @db.Uuid
  title           String   @db.VarChar(255)
  orderIndex      Int      @map("order_index")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  courseProfile      CourseProfile                    @relation(fields: [courseProfileId], references: [id], onDelete: Cascade)
  lessons            Lesson[]
  academyAssessments AcademyCourseProfileAssessment[]

  @@unique([courseProfileId, orderIndex])
  @@index([courseProfileId])
  @@map("academy_modules")
}

/// Lesson là đơn vị nội dung thực tế (VIDEO hoặc READING)
model Lesson {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId   String     @map("module_id") @db.Uuid
  type       LessonType
  title      String     @db.VarChar(255)
  orderIndex Int        @map("order_index")
  videoUrl   String?    @map("video_url") @db.Text // Only for VIDEO type
  /// Nội dung bài học dạng rich text (markdown) từ admin
  content    String?    @db.Text
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")
  transcriptionStatus String     @default("IDLE") @map("transcription_status")

  module             Module                           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress           UserLessonProgress[]
  academyAssessments AcademyCourseProfileAssessment[]
  transcriptChunks   LessonTranscriptChunk[]

  @@unique([moduleId, orderIndex])
  @@index([moduleId])
  @@map("academy_lessons")
}

/// Assignment là nội dung bài tập tự luận (Sakubun, Kaiwa) — Master/Content Bank
model Assignment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String   @db.VarChar(255)
  instructions String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  liveClassAssignments LiveClassAssignment[]

  @@map("academy_assignments")
}

// ==================================================
// DELIVERY LAYER
// ==================================================

model VodPackage {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseProfileId String    @map("course_profile_id") @db.Uuid
  code            String    @unique @db.VarChar(150)
  title           String    @db.VarChar(255)
  price           Decimal   @db.Decimal(12, 2)
  discountPrice   Decimal?  @map("discount_price") @db.Decimal(12, 2)
  status          VodStatus @default(DRAFT)
  rejectionReason String?   @map("rejection_reason") @db.Text
  thumbnailUrl   String?   @map("thumbnail_url") @db.Text
  submittedForApprovalAt DateTime? @map("submitted_for_approval_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  instructorId    String?       @map("instructor_id") @db.Uuid
  instructor      User?         @relation("AcademyVodTeacher", fields: [instructorId], references: [id], onDelete: SetNull)

  courseProfile CourseProfile @relation(fields: [courseProfileId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  enrollments   Enrollment[]

  reviews CourseReview[]
  assignments LiveClassAssignment[]
  academyFolders AcademyFolder[]
  certificates   Certificate[]

  @@index([status])
  @@index([courseProfileId])
  @@map("academy_vod_packages")
}

/// Đợt khai giảng LIVE: một CourseProfile có thể có nhiều Cohort; mỗi Cohort chứa các [LiveClass].
/// Không dùng Cohort cho VOD — gói tự học là [VodPackage] gắn trực tiếp CourseProfile.
model Cohort {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseProfileId String       @map("course_profile_id") @db.Uuid
  code            String       @unique @db.VarChar(150)
  name            String       @db.VarChar(255)
  status          CohortStatus @default(DRAFT)
  rejectionReason String?      @map("rejection_reason") @db.Text
  submittedForApprovalAt DateTime? @map("submitted_for_approval_at")

  enrollmentOpenAt  DateTime? @map("enrollment_open_at")
  enrollmentCloseAt DateTime? @map("enrollment_close_at")
  startDate         DateTime? @map("start_date")
  endDate           DateTime? @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  courseProfile CourseProfile @relation(fields: [courseProfileId], references: [id], onDelete: Cascade)
  liveClasses   LiveClass[]
  orderItems    OrderItem[]

  @@index([status])
  @@index([courseProfileId])
  @@map("academy_cohorts")
}

/// Một lớp cụ thể trong một Cohort (cùng đợt/kỳ). Enrollment LIVE trỏ vào đây, không trỏ Cohort.
model LiveClass {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohortId     String          @map("cohort_id") @db.Uuid
  code         String          @unique @db.VarChar(50)
  name         String          @db.VarChar(150)
  status       LiveClassStatus @default(DRAFT)
  instructorId String?         @map("instructor_id") @db.Uuid
  maxStudents  Int?            @map("max_students")
  price         Decimal?        @db.Decimal(12, 2)
  discountPrice Decimal?        @map("discount_price") @db.Decimal(12, 2)
  thumbnailUrl  String?         @map("thumbnail_url") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  cohort     Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  instructor User?  @relation("AcademyClassTeacher", fields: [instructorId], references: [id], onDelete: SetNull)

  enrollments          Enrollment[]
  assignments          LiveClassAssignment[]
  liveSchedules        LiveSchedule[]
  orderItems           OrderItem[]
  liveScheduleSessions LiveScheduleSession[]
  tickets              Ticket[]
  certificates         Certificate[]
  academySharedFolders AcademyFolder[]
  reviews              CourseReview[]

  @@index([cohortId])
  @@map("academy_live_classes")
}

model LiveClassAssignment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  liveClassId   String?   @map("live_class_id") @db.Uuid
  vodPackageId  String?   @map("vod_package_id") @db.Uuid
  assignmentId  String    @map("assignment_id") @db.Uuid
  titleOverride String?   @map("title_override") @db.VarChar(255)
  openAt        DateTime? @map("open_at")
  deadline      DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  liveClass   LiveClass?             @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  vodPackage  VodPackage?            @relation(fields: [vodPackageId], references: [id], onDelete: Cascade)
  assignment  Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@unique([liveClassId, assignmentId])
  @@unique([vodPackageId, assignmentId])
  @@index([liveClassId])
  @@index([vodPackageId])
  @@map("academy_live_class_assignments")
}

model UserLessonProgress {
