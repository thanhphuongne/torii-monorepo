model ClassAttendance {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  status     String   @db.VarChar(20) // PRESENT, ABSENT, LATE, EXCUSED
  recordedAt DateTime @default(now()) @map("recorded_at")

  session LiveScheduleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@map("academy_class_attendances")
}

model CourseReview {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String @map("enrollment_id") @db.Uuid
  userId       String @map("user_id") @db.Uuid

  vodPackageId String? @map("vod_package_id") @db.Uuid
  liveClassId  String? @map("live_class_id") @db.Uuid

  rating      Int // 1-5
  title       String?   @db.VarChar(255)
  content     String?   @db.Text
  status      String    @default("PUBLISHED") @db.VarChar(20) // PENDING, PUBLISHED, HIDDEN, REJECTED
