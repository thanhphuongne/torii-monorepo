// --- Gamification ---

model UserGamification {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // --- XP & Level System ---
  level     Int @default(1)
  currentXp Int @default(0) @map("current_xp") // XP hiện tại ở level này
  totalXp   Int @default(0) @map("total_xp") // Tổng XP tích lũy (dùng để đua Top)

  // --- Currency (Economy - Chuẩn bị sẵn cho tương lai) ---
  points Int @default(0) // Điểm thưởng dùng để đổi mã giảm giá
  gems   Int @default(0) // Đơn vị cao cấp (nếu có)

  // --- Streak System (Gộp từ UserStreak cũ vào đây) ---
  currentStreak  Int     @default(0) @map("current_streak")
  longestStreak  Int     @default(0) @map("longest_streak")
  lastActiveDate String? @map("last_active_date") @db.VarChar(10) // YYYY-MM-DD
  freezeCount    Int     @default(0) @map("freeze_count") // Số 'bùa' bảo vệ streak

  // --- Stats Aggregate (Lưu sẵn để đỡ phải count từ bảng khác) ---
  totalActiveDays    Int @default(0) @map("total_active_days")
  weeklyActiveCount  Int @default(0) @map("weekly_active_count")
  monthlyActiveCount Int @default(0) @map("monthly_active_count")
  consecutiveActiveDays Int @default(0) @map("consecutive_active_days") // Số ngày học liên tiếp để hồi phục khiên

  // --- UI/UX flags (toast/modal gating) ---
  lastToastShownDate String? @map("last_toast_shown_date") @db.VarChar(10) // YYYY-MM-DD

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Index tối ưu
  @@index([totalXp(sort: Desc)]) // Index quan trọng nhất để lấy Leaderboard (Bảng xếp hạng)
  @@index([userId])
  @@map("user_gamification")
}

model Achievement {
