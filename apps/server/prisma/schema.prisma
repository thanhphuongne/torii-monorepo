// --- Files ---

model FileAsset {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // File Identification
  fileUrl String @unique @map("file_url") @db.Text

  // File Details
  mimeType String? @map("mime_type") @db.VarChar(100)
  fileSize BigInt? @map("file_size")
  isPublic Boolean @default(false) @map("is_public")

  // Upload Status: 'pending' | 'uploaded' | 'failed'
  status String @default("pending") @db.VarChar(20)

  // Flexible Metadata (JSONB)
  metadata     Json?   @default("{}") @map("metadata")
  ownerId      String? @map("owner_id") @db.Uuid
  moduleOrigin String? @map("module_origin") @db.VarChar(50) // 'USER', 'COURSE', 'CHAT'

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  setCardSourceDocs SetCard[]         @relation("SetCardSourceDocument")
  academyResources  AcademyResource[]

  @@index([ownerId])
  @@index([fileUrl])
  @@index([status])
  @@map("file_assets")
}

// --- Blog ---

model Blog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(255)
  excerpt       String?   @db.Text
  content       String    @db.Text
  coverImageUrl String?   @map("cover_image_url") @db.Text
  authorId      String    @map("author_id") @db.Uuid
  status        String    @default("draft") @db.VarChar(20) // draft, published, archived
  publishedAt   DateTime? @map("published_at")
  viewCount     Int       @default(0) @map("view_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("blogs")
}

// --- Discussion & Social ---

model Comment {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String  @map("user_id") @db.Uuid
  parentCommentId String? @map("parent_comment_id") @db.Uuid // For nested replies

  content   String   @db.Text
  status    String   @default("approved") @db.VarChar(20) // pending, approved, spam, deleted
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?        @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies Comment[]       @relation("CommentReplies")
  likes   CommentLike[]
  targets CommentTarget[]

  @@index([userId])
  @@index([parentCommentId])
  @@index([createdAt(sort: Desc)])
  @@map("comments")
}

model CommentTarget {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId  String   @map("comment_id") @db.Uuid
  targetId   String   @map("target_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(20) // BLOG, COURSE_RUN, etc.
  createdAt  DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, targetId, targetType])
  @@index([targetId, targetType])
  @@map("comment_targets")
}

model CommentLike {
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_likes")
}

// --- Notifications ---

model Notification {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  title            String    @db.VarChar(255)
  message          String    @db.Text
  notificationType String?   @map("notification_type") @db.VarChar(50)
  /// Idempotency key: dùng để chống gửi trùng cho các job/trigger (per-user).
  /// VD: "LIVE_SESSION:STARTS_IN_30_MIN:<sessionId>"
  dedupeKey        String?   @map("dedupe_key") @db.VarChar(160)
  metadata         Json?     @map("data")
  isRead           Boolean   @default(false) @map("is_read")
  readAt           DateTime? @map("read_at")
  sentVia          String[]  @default([]) @map("sent_via") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@unique([userId, dedupeKey])
  @@map("notifications")
}

model UserDeviceToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  token      String   @unique
  platform   String? // 'android', 'ios'
  deviceName String?  @map("device_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_device_tokens")
}

