  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @default(now()) @updatedAt @map("updated_at")

  liveClass  LiveClass?        @relation(fields: [liveClassId], references: [id], onDelete: SetNull)
  vodPackage VodPackage?       @relation(fields: [vodPackageId], references: [id], onDelete: SetNull)
  resources  AcademyResource[]

  @@index([liveClassId])
  @@index([vodPackageId])
