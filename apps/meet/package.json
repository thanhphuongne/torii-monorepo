{
  "name": "meet",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format:check": "prettier --check src/**/*.{jsx,ts,tsx}",
    "prepare": "husky",
    "size-limit": "pnpm run build && size-limit --json"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.10.2",
    "@excalidraw/excalidraw": "0.18.0",
    "@headlessui/react": "2.2.9",
    "@nats-io/jetstream": "3.3.0",
    "@nats-io/nats-core": "3.3.0",
    "@reduxjs/toolkit": "2.11.2",
    "@tensorflow-models/body-pix": "2.2.1",
    "@tensorflow/tfjs": "4.22.0",
    "@workspace/protocol": "workspace:*",
    "@workspace/ui": "workspace:*",
    "axios": "1.13.2",
    "clsx": "2.1.1",
    "copy-text-to-clipboard": "3.2.2",
    "es-toolkit": "1.43.0",
    "eventemitter3": "5.0.1",
    "framer-motion": "12.23.26",
    "idb": "8.0.3",
    "livekit-client": "2.16.1",
    "lucide-react": "^0.475.0",
    "marked": "17.0.1",
    "mobile-detect": "1.4.5",
    "nosleep.js": "0.12.0",
    "react": "19.2.1",
    "react-cool-virtual": "0.7.0",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "19.2.1",
    "react-draggable": "4.5.0",
    "react-hotkeys-hook": "5.2.1",
    "react-player": "3.4.0",
    "react-redux": "9.2.0",
    "react-toastify": "11.0.5",
    "resumablejs": "1.1.0",
    "sanitize-html": "2.17.0"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "0.1.3",
    "@size-limit/preset-app": "12.0.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/emscripten": "1.41.5",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.0",
    "@vitejs/plugin-react": "5.1.2",
    "eslint": "^9.39.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "oxlint": "1.33.0",
    "prettier": "3.7.4",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-clean": "2.0.1",
    "vite-plugin-oxlint": "1.5.0",
    "vite-plugin-static-copy": "3.1.4"
  },
  "lint-staged": {
    "**/*.{jsx,ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "**/*.{css,scss}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "name": "JS files",
      "path": [
        "dist/assets/js/*.js"
      ]
    },
    {
      "name": "CSS files",
      "path": [
        "dist/assets/css"
      ]
    },
    {
      "name": "Image files",
      "path": [
        "dist/assets/imgs",
        "dist/assets/backgrounds"
      ]
    },
    {
      "name": "Font files",
      "path": "dist/assets/fonts"
    },
    {
      "name": "Webassembly files",
      "path": [
        "dist/assets/js/*.wasm",
        "dist/assets/models"
      ]
    },
    {
      "name": "All assets",
      "path": "dist/assets"
    }
  ]
}