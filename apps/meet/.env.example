# Meet Environment Variables
VITE_API_URL=http://localhost:8080
MEET_PORT=5180

# LiveKit Features
VITE_ENABLE_DYNACAST=true
VITE_ENABLE_SIMULCAST=true
VITE_VIDEO_CODEC=vp8
VITE_STOP_MIC_TRACK_ON_MUTE=true
VITE_FOCUS_ACTIVE_SPEAKER_WEBCAM=true
VITE_DISABLE_DARK_MODE=false

# Default Resolutions & Presets
VITE_DEFAULT_WEBCAM_RESOLUTION=h720
VITE_DEFAULT_SCREEN_SHARE_RESOLUTION=h1080fps15
VITE_DEFAULT_AUDIO_PRESET=music

# Assets & Customization
# Note: Complex types should be valid JSON strings
VITE_STATIC_ASSETS_PATH=

# Login nhanh (dev): trùng apiKey / apiSecret cấu hình phía server (WAJLC auth)
# VITE_MEET_LOGIN_API_KEY=
# VITE_MEET_LOGIN_API_SECRET=
# VITE_CUSTOM_LOGO={"main_logo_light": "https://...", "main_logo_dark": "https://..."}
# VITE_DESIGN_CUSTOMIZATION={"primary_color": "#004D90", "secondary_color": "#24AEF7"}
# VITE_WHITEBOARD_PRELOADED_LIBRARY_ITEMS=["https://..."]
# VITE_VIRTUAL_BACKGROUND_IMAGES=["https://..."]
